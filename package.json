{
  "name": "@steel-dev/convex",
  "version": "0.2.2",
  "description": "Convex component wrapper for Steel",
  "type": "module",
  "private": false,
  "license": "MIT",
  "author": "Steel <team@steel.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/steel-dev/steel-convex"
  },
  "homepage": "https://github.com/steel-dev/steel-convex",
  "bugs": {
    "url": "https://github.com/steel-dev/steel-convex/issues"
  },
  "keywords": [
    "convex",
    "steel",
    "browser",
    "automation",
    "component"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "convex:prepare": "CONVEX_AGENT_MODE=anonymous npx convex dev --local --once",
    "codegen": "convex codegen --component-dir ./src/component",
    "codegen:verify": "bash ./scripts/run-with-local-convex.sh npm run codegen",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:prepared": "vitest run",
    "test": "npm run convex:prepare && npm run test:prepared",
    "test:unit": "npm run convex:prepare && vitest run test/sessions.unit.test.ts",
    "test:integration": "npm run convex:prepare && vitest run test/sessions.integration.test.ts",
    "release:verify": "node scripts/release-verify.js",
    "release:check": "npm run codegen:verify && npm run build && npm run release:verify && npm run test:prepared",
    "release": "npm run release:check",
    "publish:dry-run": "npm run release:check && npm pack --dry-run",
    "release:publish": "npm run release && npm publish --access public",
    "prepublishOnly": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./convex.config.js": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    },
    "./convex.config": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    },
    "./_generated/component.js": {
      "default": "./_generated/component.js"
    },
    "./_generated/component": {
      "default": "./_generated/component.js"
    },
    "./test": {
      "types": "./dist/test.d.ts",
      "default": "./dist/test.js"
    }
  },
  "files": [
    "dist/",
    "_generated/component.js",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "peerDependencies": {
    "convex": "^1.32.0"
  },
  "dependencies": {
    "steel-sdk": "^0.17.0"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "convex-test": "^0.0.41",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
