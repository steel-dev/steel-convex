{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ES2021", "dom", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["vitest/globals"]
  },
  "include": ["../ test/**/*.ts", "../src/**/*.ts", "../example/**/*.ts"]
}
